# MiMo API Configuration
MIMO_API_KEY=your_mimo_api_key_here
MIMO_API_BASE=https://api.xiaomimimo.com/v1

# Model Selection
MIMO_MODEL_OMNI=mimo-v2.5-omni
MIMO_MODEL_PRO=mimo-v2.5-pro
MIMO_MODEL_TTS=mimo-v2.5-tts

# Context Window
MIMO_MAX_CONTEXT=1000000
MIMO_MAX_OUTPUT=32768
MIMO_TEMPERATURE=0.3

# Application
OMNIMEMO_OUTPUT_DIR=./output
OMNIMEMO_LANG=zh
OMNIMEMO_VERBOSE=false
